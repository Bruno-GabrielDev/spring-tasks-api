<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Arquivo deve terminar com nova linha -->
    <module name="NewlineAtEndOfFile"/>

    <!-- Linha com no maximo 120 caracteres (nivel Checker, nao TreeWalker) -->
    <module name="LineLength">
        <property name="max" value="120"/>
    </module>

    <!-- Sem espacos em branco no final das linhas -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Linha nao pode terminar com espacos em branco."/>
    </module>

    <module name="TreeWalker">

        <!-- Nomenclatura: Classes PascalCase -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Nomenclatura: metodos camelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Nomenclatura: variaveis e parametros camelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Nomenclatura: constantes UPPER_SNAKE_CASE -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- Imports: proibir wildcard -->
        <module name="AvoidStarImport"/>

        <!-- Imports: sem imports nao utilizados -->
        <module name="UnusedImports"/>

        <!-- Tamanho: metodo com no maximo 40 linhas -->
        <module name="MethodLength">
            <property name="max" value="40"/>
        </module>

        <!-- Tamanho: maximo de 7 parametros por metodo -->
        <module name="ParameterNumber">
            <property name="max" value="7"/>
        </module>

        <!-- Boas praticas: bloco vazio deve ter comentario -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>

        <!-- Boas praticas: sempre usar chaves em if/else/for/while -->
        <module name="NeedBraces"/>

        <!-- Boas praticas: proibir System.out.println -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="System\.out\.print"/>
            <property name="message" value="Nao use System.out.println. Use um Logger."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Boas praticas: sem modificadores redundantes -->
        <module name="RedundantModifier"/>

        <!-- Formatacao: espaco apos virgulas -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI"/>
        </module>

        <!-- Formatacao: sem espaco antes de ponto-e-virgula -->
        <module name="NoWhitespaceBefore">
            <property name="tokens" value="SEMI, POST_INC, POST_DEC"/>
        </module>

        <!-- Formatacao: parenteses sem espaco interno -->
        <module name="ParenPad">
            <property name="option" value="nospace"/>
        </module>

        <!-- Formatacao: chave de abertura na mesma linha -->
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>

        <!-- Formatacao: chave de fechamento em linha propria -->
        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>

    </module>
</module>